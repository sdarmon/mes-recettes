---
// Composant autonome pour le calcul des pizzas
---

<div class="pizza-calc no-print">
  <div class="calc-header">🍕 Calculateur de Pâte</div>

  <div class="grid grid-cols-2 gap-4">
    <div class="flex flex-col gap-2 ">
      <label for="piz-size">Taille de pizza</label>
      <select id="piz-size">
        <option value="142.85714285714286">Petite (248g = 30cm)</option>
        <option value="150">Moyenne (260g = 33cm)</option>
        <option value="166.66666666666667" selected >Grande (289g = 36cm)</option>
      </select>
    </div>

    <div class="flex flex-col gap-2">
      <label for="piz-count">Nombre de pizzas</label>
      <input type="number" id="piz-count" min="0.1" step="0.1" />
    </div>
  </div>
</div>

<style>
  .pizza-calc {
    margin: 2rem 0;
    padding: 1.5rem;
    background: rgba(var(--color-card-muted), 0.1);
    border: 1px solid var(--color-border);
    border-radius: 12px;
    font-family: "Exo 2", sans-serif;
  }
  .calc-header {
    font-weight: bold;
    color: var(--color-accent);
    margin-bottom: 1rem;
    text-transform: uppercase;
  }
  label {
    font-size: 0.8rem;
    opacity: 0.8;
    color: var(--foreground);
    padding: 2px 8px;
  }
  select,
  input {
    background: var(--color-fill);
    border: 1px solid var(--color-border);
    color: var(--foreground);
    padding: 8px;
    border-radius: 6px;
    width: 100%;
    height: 40px;
  }
</style>
