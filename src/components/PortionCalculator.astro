---
export interface Props {
  initialServings?: number;
  label?: string;
  v?: number;
  }
// On récupère tout en une seule fois
const { initialServings, label = "Personnes", v } = Astro.props;
---

{
  v !== undefined ? (
    /* CAS 1 : On affiche l'ingrédient si 'v' est présent */
    <span class="qty" data-base={v}>
      {v}
    </span>
  ) : (
    /* CAS 2 : On affiche le bloc de calcul si 'v' est absent */
    <div class="calculator-box no-print">
      <label for="servings-input">Nombre de {label} : </label>
      <input
        type="number"
        id="servings-input"
        value={initialServings}
        min="1"
        max="100000"
        data-initial={initialServings}
      />
    </div>
  )
}

<style>
  /* Style de l'ingrédient */
  .qty {
    font-weight: bold;
    color: var(--color-accent);
  }
  /* Style de la boîte de contrôle */
  .calculator-box {
    margin: 1rem 0;
    padding: 12px;
    background: rgba(var(--color-card-muted), 0.1);
    border-radius: 8px;
    border: 1px solid var(--color-border);
    font-family: "Exo 2", sans-serif;
  }
  input {
    background: transparent;
    border: 1px solid var(--color-border);
    border-radius: 4px;
    padding: 2px 8px;
    width: 80px;
    color: var(--color-accent);
    font-weight: bold;
  }
</style>

