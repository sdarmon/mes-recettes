---
export interface Props {
  initialServings: number;
  label?: string;
}
const { initialServings , label = "Personnes"} = Astro.props;
---

<div class="calculator-box">
  <label for="servings-input">Nombre de {label} : </label>
  <input
    type="number"
    id="servings-input"
    value={initialServings}
    min="1"
    max="50"
    data-initial={initialServings}
  />
</div>

<script>
  // On précise que l'élément est un HTMLInputElement pour accéder à .value
  const input = document.getElementById('servings-input') as HTMLInputElement | null;
  // On utilise une valeur par défaut au cas où le dataset est vide
  const initialServings = input ? parseFloat(input.dataset.initial || "1") : 1;

  if (input) {
    input.addEventListener('input', (e) => {
      // On s'assure que la cible du clic est bien notre input
      const target = e.target as HTMLInputElement;
      const newServings = parseFloat(target.value) || 1;
      const ratio = newServings / initialServings;

      // On précise que el est un HTMLElement pour accéder à .dataset
      document.querySelectorAll('.qty').forEach(el => {
        const htmlEl = el as HTMLElement;
        const baseQty = parseFloat(htmlEl.dataset.base || "0");

        if (baseQty) {
          let result: string | number = baseQty * ratio;
          // On s'assure que le résultat devient une chaîne de caractères pour textContent
          result = result % 1 !== 0 ? result.toFixed(1) : result.toString();
          htmlEl.textContent = result;
        }
      });
    });
  }
</script>
