---
import { actions } from "astro:actions";

interface Props {
  postSlug: string;
}

const { postSlug } = Astro.props;
---

<!-- 1. On retire 'method' et 'action' du form pour éviter le rechargement 404 -->
<form id="comment-form" class="mb-8">
  <input type="hidden" name="postSlug" value={postSlug} />

  <div class="mb-4">
    <label for="name">Pseudo:</label>
    <input
      type="text"
      id="name"
      name="name"
      required
      class="w-full rounded border p-2"
    />
  </div>

  <div class="mb-4">
    <label for="email">E-miel (Optionnel) 🐝:</label>
    <input
      type="email"
      id="email"
      name="email"
      class="w-full rounded border p-2"
    />
  </div>

  <div class="mb-4">
    <label for="message">Message:</label>
    <textarea
      id="message"
      name="message"
      required
      class="w-full rounded border p-2"></textarea>
  </div>

  <button type="submit" class="rounded bg-[#a4cf0a] px-4 py-2 text-black">
    Envoyer le commentaire
  </button>

  <p id="form-msg" class="mt-2 hidden"></p>
</form>

<script>
  import { actions } from "astro:actions";

  const form = document.getElementById("comment-form") as HTMLFormElement;
  const msg = document.getElementById("form-msg");

  form?.addEventListener("submit", async e => {
    e.preventDefault();
    const formData = new FormData(form);

    // 2. On appelle l'action en JavaScript
    const { data, error } = await actions.addComment(formData);

    if (msg) {
      msg.classList.remove("hidden");
      if (error) {
        msg.textContent = "Erreur lors de l'envoi...";
        msg.className = "mt-2 text-red-500";
      } else {
        msg.textContent =
          "Merci ! Votre commentaire a été ajouté (il apparaîtra dans quelques instants).";
        msg.className = "mt-2 text-green-600";
        form.reset();
        // Optionnel : recharger la page après 2 secondes pour voir le commentaire
        setTimeout(() => window.location.reload(), 2000);
      }
    }
  });
</script>
