---
---

<div class="mt-16 w-full max-w-3xl mx-auto border-t border-border pt-12 no-print">
  <h2 class="text-2xl font-bold mb-8 text-accent">Livre d'or & Questions</h2>

  <!-- Le conteneur où Waline va s'afficher -->
  <div id="waline"></div>
</div>

<!-- Import du CSS de Waline -->
<link rel="stylesheet" href="https://unpkg.com/@waline/client@v3/dist/waline.css" />

<script>
  import { init } from '@waline/client';

  let walineInstance: any = null;

  function initWaline() {
    const container = document.querySelector('#waline');
    if (!container) return;

    // Nettoyage si une instance existe déjà (évite les doublons avec Astro transitions)
    if (walineInstance) {
      walineInstance.destroy();
    }

    walineInstance = init({
      el: '#waline',
      serverURL: 'https://recette-vercel.vercel.app', // ⚠️ REMPLACE PAR TON URL VERCEL
      lang: 'fr',
      dark: 'html[data-theme="dark"]', // Détection automatique du thème AstroPaper
      search: false, // Plus léger
      reaction: true, // Permet des réactions type emoji sur les recettes
      requiredMeta: ['nick'], // Seul le pseudo est obligatoire
      wordLimit: 500,
      imageUploader: false, // Désactivé par défaut pour la sécurité
    });
  }

  // Initialisation au chargement et lors de la navigation Astro
  document.addEventListener('astro:page-load', initWaline);
</script>

<style is:global>
  /* Personnalisation aux couleurs de SashaDarmon.fr */
  :root {
    --waline-theme-color: #95ec38 !important; /* Ton vert lime */
    --waline-active-color: #5fa905 !important;
  }

  /* Ajustements pour le mode sombre d'AstroPaper */
  html[data-theme="dark"] {
    --waline-white: #141717 !important;
    --waline-light-grey: #1e2323 !important;
    --waline-dark-grey: #9ca3af !important;
    --waline-color: #f0f4f4 !important;
    --waline-bgcolor: #141717 !important;
    --waline-bgcolor-light: #1e2323 !important;
    --waline-border-color: #2d3535 !important;
    --waline-disable-bgcolor: #121414 !important;
  }

  /* On force le conteneur à prendre toute la hauteur nécessaire */
  .wl-panel {
    margin-bottom: 2rem;
    border-radius: 12px !important;
  }
</style>