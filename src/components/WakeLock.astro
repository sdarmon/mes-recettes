---

<button id="wake-lock-btn" class="wake-btn">
  🍳 Mode Cuisine (Écran allumé)
</button>

<script>
  let wakeLock: any = null; // On autorise n'importe quel type pour le sentinel
  const btn = document.getElementById('wake-lock-btn') as HTMLButtonElement | null;

  const requestWakeLock = async () => {
    try {
      if ('wakeLock' in navigator) {
        wakeLock = await (navigator as any).wakeLock.request('screen');
        if (btn) {
          btn.textContent = "🔥 Mode Cuisine Actif";
          btn.classList.add('active');
        }
      }
    } catch (err: any) {
      // On précise que err est de type any pour accéder à .name et .message
      console.error(`Erreur Wake Lock: ${err.name}, ${err.message}`);
    }
  };

  const releaseWakeLock = () => {
    if (wakeLock !== null) {
      wakeLock.release().then(() => {
        wakeLock = null;
        if (btn) {
          btn.textContent = "🍳 Activer le Mode Cuisine";
          btn.classList.remove('active');
        }
      });
    }
  };

  if (btn && 'wakeLock' in navigator) {
    btn.addEventListener('click', () => {
      if (wakeLock === null) {
        requestWakeLock();
      } else {
        releaseWakeLock();
      }
    });
  } else if (btn) {
    btn.style.display = 'none';
  }
</script>

<style>
  .wake-btn {
    display: block;
    width: 100%;
    padding: 12px;
    margin-bottom: 0rem;
    background: rgb(0 0 0 / 0, 05);
    border: 2px solid #e5e7eb;
    border-radius: 8px;
    font-weight: bold;
    cursor: pointer;
    text-align: center;
    transition: 0.3s;
  }
  .wake-btn.active {
    background: #fee2e2;
    border-color: #ef4444;
    color: #991b1b;
  }
</style>
