---
import { db, Comment, eq, desc } from "astro:db";

interface Props {
  postSlug: string;
}

const { postSlug } = Astro.props;

const comments = await db
  .select()
  .from(Comment)
  .where(eq(Comment.postSlug, postSlug))
  .orderBy(desc(Comment.createdAt));
---

<div class="space-y-4">
  {
    comments.length === 0 ? (
      /* Message affiché s'il n'y a pas de commentaires */
      <div class="rounded border-2 border-dashed border-gray-200 p-8 text-center text-gray-500">
        <p> 0 commentaire pour l'instant :(</p>
      </div>
    ) : (
      /* Liste des commentaires s'il y en a */
      comments.map(comment => (
        <div class="rounded bg-[#a4cf0a] p-4 text-gray-800">
          <div class="font-bold">{comment.name}</div>
          <div class="text-sm text-gray-800">
            {comment.createdAt.toLocaleDateString()}
          </div>
          <div class="mt-2">{comment.message}</div>
        </div>
      ))
    )
  }
</div>
