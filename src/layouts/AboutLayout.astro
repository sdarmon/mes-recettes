---
// On reste en mode statique pour que Pagefind soit content
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Layout from "./Layout.astro";
import { SITE } from "@/config";
import Main from "@/layouts/Main.astro";
---

<Layout title={`About | ${SITE.title}`}>
  <Header />
  <Main pageTitle="About" pageDesc="Administration">
    <div id="public-content">
      <p>Bienvenue sur mon carnet de recettes.</p>
    </div>

    <!-- La zone admin est cachée par défaut avec "hidden" -->
    <div
      id="admin-zone"
      class="mt-20 hidden border-t-2 border-accent pt-10 text-gray-800"
    >
      <h2 class="text-2xl font-bold text-accent">
        Zone Admin : Ajouter une recette
      </h2>

      <form id="recipe-form" class="mt-4 flex flex-col gap-4">
        <!-- Le champ adminKey sera rempli par le script -->
        <input type="hidden" name="adminKey" id="adminKeyInput" value="" />

        <div class="flex flex-col">
          <label class="font-bold">Auteur :</label>
          <input
            type="text"
            name="author"
            placeholder="Sasha"
            class="rounded border p-2"
            required
          />
        </div>

        <div class="flex flex-col">
          <label class="font-bold">Titre :</label>
          <input
            type="text"
            name="title"
            placeholder="Ma super recette"
            class="rounded border p-2"
            required
          />
        </div>

        <div class="flex flex-col">
          <label class="font-bold">Description :</label>
          <textarea name="description" class="rounded border p-2" required
          ></textarea>
        </div>

        <div class="flex flex-col">
          <label class="font-bold">Tags :</label>
          <input
            type="text"
            name="tags"
            placeholder="pizza, dessert"
            class="rounded border p-2"
          />
        </div>

        <div class="flex flex-col">
          <label class="font-bold">Contenu Markdown :</label>
          <textarea
            name="content"
            class="h-64 rounded border p-2 font-mono"
            required></textarea>
        </div>

        <button
          type="submit"
          class="rounded bg-[#a4cf0a] p-3 font-bold text-black hover:opacity-90"
        >
          🚀 Publier sur GitHub
        </button>
      </form>
      <p id="msg" class="mt-4 hidden rounded p-3 text-center"></p>
    </div>
  </Main>
  <Footer />
</Layout>

<script>
  import { actions } from "astro:actions";

  // 1. GESTION DE L'AFFICHAGE (Côté Client)
  const urlParams = new URLSearchParams(window.location.search);
  const adminValue = urlParams.get("admin");

  if (adminValue === "kakoukakou") {
    // On montre la zone admin
    const adminZone = document.getElementById("admin-zone");
    if (adminZone) adminZone.classList.remove("hidden");

    // On remplit le champ caché pour l'Action
    const keyInput = document.getElementById(
      "adminKeyInput"
    ) as HTMLInputElement;
    if (keyInput) keyInput.value = adminValue;
  }

  // 2. GESTION DE L'ENVOI
  const form = document.getElementById("recipe-form") as HTMLFormElement;
  const msg = document.getElementById("msg");

  form?.addEventListener("submit", async e => {
    e.preventDefault();
    if (!confirm("Publier cette recette ?")) return;

    if (msg) {
      msg.classList.remove("hidden", "bg-red-100", "bg-green-100");
      msg.textContent = "⏳ Envoi à GitHub en cours...";
      msg.classList.add("bg-blue-100", "text-blue-800");
    }

    const formData = new FormData(form);
    const { data, error } = await actions.addRecipe(formData);

    if (msg) {
      if (error) {
        msg.textContent = "❌ Erreur : " + error.message;
        msg.classList.replace("bg-blue-100", "bg-red-100");
        msg.classList.add("text-red-800");
      } else {
        msg.textContent =
          "✅ Recette envoyée ! Le site sera à jour dans 2-3 min.";
        msg.classList.replace("bg-blue-100", "bg-green-100");
        msg.classList.add("text-green-800", "border-2", "border-green-500");
        form.reset();
      }
    }
  });
</script>
