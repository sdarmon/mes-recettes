---
// On reste en mode statique pour que Pagefind soit content
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Layout from "./Layout.astro";
import { SITE } from "@/config";
import Main from "@/layouts/Main.astro";

// Modèle de recette pour pré-remplir le formulaire
const recipeTemplate = `Utilisez la balise <C v="NOMBRE" /> pour les quantités : elle permet aux lecteurs d'adapter la recette selon leurs besoins !

## Ingrédients

* <C v="4" /> bananes mûres
* <C v="180" />g de compote sans sucre
* <C v="200" />g de chocolat en morceaux

## Préparation

1. **Préchauffage :** Four à 180°C.
2. **Mélange :** Écrasez les <C v="4" /> bananes et mélangez avec le reste.
3. **Cuisson :** Enfournez 25 minutes.`;
---

<Layout title={`About | ${SITE.title}`}>
  <Header />
  <Main pageTitle="About" pageDesc="Administration">
    <div id="public-content">
      <p>
        Bienvenue sur mon carnet de recettes.<br />
        Aller à https://recette.sashadarmon.fr/about/?admin=M2P pour ajouter une recette.
      </p>
    </div>

    <div
      id="admin-zone"
      class="mt-20 border-t-2 border-accent pt-10 text-gray-900 dark:text-white"
    >
      <h2 class="mb-6 text-2xl font-bold text-accent">
        Zone Admin : Ajouter une recette
      </h2>

      <form id="recipe-form" class="flex flex-col gap-4">
        <input type="hidden" name="adminKey" id="adminKeyInput" value="" />

        <!-- Ligne Auteur / Titre -->
        <div class="grid grid-cols-1 gap-4 md:grid-cols-2">
          <div class="flex flex-col">
            <label class="font-bold">Auteur :</label>
            <input
              type="text"
              name="author"
              class="rounded border bg-white p-2 dark:border-zinc-700 dark:bg-zinc-900"
              required
            />
          </div>
          <div class="flex flex-col">
            <label class="font-bold">Titre :</label>
            <input
              type="text"
              name="title"
              class="rounded border bg-white p-2 dark:border-zinc-700 dark:bg-zinc-900"
              required
            />
          </div>
        </div>

        <!-- Ligne Quantité / Unité -->
        <div class="grid grid-cols-2 gap-4">
          <div class="flex flex-col">
            <label class="font-bold">Quantité de base :</label>
            <input
              type="number"
              name="personnes"
              class="rounded border bg-white p-2 dark:border-zinc-700 dark:bg-zinc-900"
              required
            />
          </div>
          <div class="flex flex-col">
            <label class="font-bold">Unité :</label>
            <input
              type="text"
              name="unite"
              class="rounded border bg-white p-2 dark:border-zinc-700 dark:bg-zinc-900"
              required
            />
          </div>
        </div>

        <div class="flex flex-col">
          <label class="font-bold">Description :</label>
          <textarea
            name="description"
            class="rounded border bg-white p-2 dark:border-zinc-700 dark:bg-zinc-900"
            required></textarea>
        </div>

        <div class="flex flex-col">
          <label class="font-bold">Contenu Markdown :</label>
          <textarea
            id="markdown-input"
            name="content"
            class="h-80 rounded border bg-white p-2 font-mono text-sm dark:border-zinc-700 dark:bg-zinc-900"
            required>{recipeTemplate}</textarea
          >
        </div>

        <!-- BOUTONS -->
        <div class="mt-2 flex flex-col gap-4 sm:flex-row">
          <button
            type="button"
            id="preview-btn"
            class="flex-1 rounded border-2 border-accent p-3 font-bold text-accent transition-all hover:bg-accent hover:text-white"
          >
            👁️ Voir l'aperçu (plein écran)
          </button>
          <button
            type="submit"
            class="flex-1 rounded bg-[#a4cf0a] p-3 font-bold text-black hover:opacity-90"
          >
            🚀 Publier la recette
          </button>
        </div>
      </form>

      <!-- ZONE DE PREVIEW (Toute la largeur, en dessous) -->
      <div
        id="preview-container"
        class="mt-10 hidden rounded-b-lg border-t-4 border-accent bg-white p-6 shadow-xl dark:bg-zinc-900"
      >
        <div class="mb-6 flex items-center justify-between">
          <h3 class="text-xl font-bold tracking-widest text-accent uppercase">
            Aperçu du rendu final
          </h3>
          <button
            type="button"
            onclick="document.getElementById('preview-container').classList.add('hidden')"
            class="text-sm text-gray-500 text-red-500 hover:underline"
            >Fermer l'aperçu</button
          >
        </div>

        <div
          id="preview-content"
          class="app-prose max-w-none dark:prose-invert"
        >
          <!-- Le contenu généré arrivera ici -->
        </div>
      </div>

      <p id="msg" class="mt-4 hidden rounded p-3 text-center font-bold"></p>
    </div>
  </Main>
  <Footer />
</Layout>

<script>
  import { actions } from "astro:actions";
  // Import de marked via CDN pour transformer le texte
  import { Marked } from "https://cdn.jsdelivr.net/npm/marked/lib/marked.esm.js";
  const marked = new Marked();

  const previewBtn = document.getElementById("preview-btn");
  const previewContainer = document.getElementById("preview-container");
  const previewContent = document.getElementById("preview-content");
  const markdownInput = document.getElementById(
    "markdown-input"
  ) as HTMLTextAreaElement;

  // Sélection des nouveaux champs
  const titleInput = document.querySelector(
    'input[name="title"]'
  ) as HTMLInputElement;
  const authorInput = document.querySelector(
    'input[name="author"]'
  ) as HTMLInputElement;
  const descInput = document.querySelector(
    'textarea[name="description"]'
  ) as HTMLTextAreaElement;
  const qtyInput = document.querySelector(
    'input[name="personnes"]'
  ) as HTMLInputElement;
  const unitInput = document.querySelector(
    'input[name="unite"]'
  ) as HTMLInputElement;

  previewBtn?.addEventListener("click", () => {
    if (!previewContainer || !previewContent || !markdownInput) return;

    previewContainer.classList.remove("hidden");

    let rawMarkdown = markdownInput.value;
    let processedMarkdown = rawMarkdown.replace(
      /<C v="([\d.]+)" \/>/g,
      '<strong class="text-accent underline decoration-dotted">$1</strong>'
    );

    const htmlContent = marked.parse(processedMarkdown);

    // CONSTRUCTION DU RENDU FINAL
    previewContent.innerHTML = `
      <!-- TITRE ET AUTEUR -->
      <h1 class="text-4xl font-bold text-accent mb-2">${titleInput.value || "Titre de la recette"}</h1>
      <p class="italic text-lg mb-4 text-gray-600 dark:text-gray-400">Par ${authorInput.value || "Auteur inconnu"}</p>
      
      <!-- DESCRIPTION -->
      <p class="text-xl mb-8 leading-relaxed border-l-4 border-accent pl-4 italic">
        ${descInput.value || "Pas de description renseignée."}
      </p>

      <!-- SIMULATION DU CALCULATEUR (Visuel uniquement) -->
      <div class="flex items-center gap-4 p-4 bg-gray-50 dark:bg-zinc-800 rounded-xl mb-8 border border-gray-200 dark:border-zinc-700">
        <div class="flex items-center gap-2">
            <span class="text-sm font-bold uppercase tracking-wider">Quantité :</span>
            <div class="bg-white dark:bg-zinc-900 border border-accent px-4 py-1 rounded-lg font-bold text-accent">
                ${qtyInput.value || "0"}
            </div>
        </div>
        <span class="font-medium">${unitInput.value || "unité"}</span>
        <span class="text-xs text-gray-400 ml-auto">(Simulé dans l'aperçu)</span>
      </div>

      <hr class="mb-8 border-dashed border-gray-300 dark:border-zinc-700" />
      
      <!-- CORPS DE LA RECETTE -->
      <div class="recipe-body">
        ${htmlContent}
      </div>
    `;

    previewContainer.scrollIntoView({ behavior: "smooth" });
  });

  // On récupère ce qu'il y a dans l'URL après ?admin=
  const urlParams = new URLSearchParams(window.location.search);
  const adminValue = urlParams.get("admin");

  // Si l'utilisateur a mis n'importe quoi dans ?admin=
  // on affiche le formulaire. C'est le serveur qui validera ensuite.
  if (adminValue) {
    const adminZone = document.getElementById("admin-zone");
    if (adminZone) adminZone.classList.remove("hidden");

    const keyInput = document.getElementById(
      "adminKeyInput"
    ) as HTMLInputElement;
    if (keyInput) keyInput.value = adminValue;
  }

  const form = document.getElementById("recipe-form") as HTMLFormElement;
  const msg = document.getElementById("msg");

  form?.addEventListener("submit", async e => {
    e.preventDefault();

    // Affichage d'un message d'attente
    if (msg) {
      msg.classList.remove("hidden");
      msg.textContent = "Vérification et envoi en cours...";
      msg.className = "mt-4 p-3 rounded text-center bg-blue-100 text-blue-800";
    }

    const formData = new FormData(form);
    const { data, error } = await actions.addRecipe(formData);

    if (msg) {
      if (error) {
        // C'est ici que l'erreur "Interdit" apparaîtra si le mot de passe est mauvais
        msg.textContent = "❌ " + error.message;
        msg.className =
          "mt-4 p-3 rounded text-center bg-red-100 text-red-800 font-bold";
      } else {
        msg.textContent = "✅ Recette publiée !";
        msg.className =
          "mt-4 p-3 rounded text-center bg-green-100 text-green-800 font-bold";
        form.reset();
      }
    }
  });
</script>
